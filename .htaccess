# =============================================================================
# wmajchrzak.pl — .htaccess
# Force HTTPS + non-www → www + block legacy WordPress + caching + security
# =============================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1) Force HTTPS (redirect all http://* to https://*)
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # 2) Force www (redirect wmajchrzak.pl → www.wmajchrzak.pl, canonical)
  RewriteCond %{HTTP_HOST} ^wmajchrzak\.pl$ [NC]
  RewriteRule ^(.*)$ https://www.wmajchrzak.pl/$1 [R=301,L]

  # 3) Block legacy WordPress paths (404 instead of serving wp-admin, wp-login, etc.)
  RewriteRule ^wp-admin/?.*$ - [R=404,L]
  RewriteRule ^wp-login\.php$ - [R=404,L]
  RewriteRule ^wp-content/?.*$ - [R=404,L]
  RewriteRule ^wp-includes/?.*$ - [R=404,L]
  RewriteRule ^wp-json/?.*$ - [R=404,L]
  RewriteRule ^wp-cron\.php$ - [R=404,L]
  RewriteRule ^xmlrpc\.php$ - [R=404,L]
  RewriteRule ^wp-config\.php$ - [R=404,L]
  RewriteRule ^wp-config-sample\.php$ - [R=404,L]
  RewriteRule ^readme\.html$ - [R=404,L]
  RewriteRule ^license\.txt$ - [R=404,L]

  # 4) Priority: serve index.html over WordPress index.php
  DirectoryIndex index.html index.php
</IfModule>

# 5) Compression (gzip)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# 6) Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# 7) Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # Block exposing PHP version
  Header unset X-Powered-By
</IfModule>

# 8) Disable directory listing
Options -Indexes

# 9) Block access to sensitive files
<FilesMatch "^\.|\.(env|log|sql|md|json|yml|yaml|ini|conf|bak|old|orig)$">
  Require all denied
</FilesMatch>
